# Digimos — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# === Application ===
NODE_ENV=production

# === Database ===
# Path to the SQLite database file (default: ./database.db in cwd)
DATABASE_PATH=./database.db

# === Seeding (used only when running: npm run db:seed) ===
# Set this before seeding to define the initial superadmin password.
# Remove or leave empty after seeding is complete.
SEED_PASSWORD=change-me-to-a-strong-password
